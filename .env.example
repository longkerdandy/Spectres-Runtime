# Spectres Runtime — config TEMPLATE (committed; no real secrets).
# Copy to `.env` (git-ignored) and fill in real values there.
# Keys map 1:1 to `config.Settings`, except DATABASE_USERNAME & DATABASE_PASSWORD (compose-only).

# --- Datastore ---------------------------------------------------------------
# Postgres role credentials. Single source of truth — referenced by DATABASE_URL
# below and read by docker/compose.yaml (via `--env-file .env`). No defaults.
DATABASE_USERNAME=replace-me-in-dotenv
DATABASE_PASSWORD=replace-me-in-dotenv

# App's DB connection (the only datastore key Settings reads). ${...} are expanded by
# python-dotenv, so user/password live in one place. Must define both above.
DATABASE_URL=postgresql+psycopg://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@localhost:5532/spectres_runtime

# --- Embedding provider (hosted, OpenAI-compatible) --------------------------
# Model name is a DATA CONTRACT: changing it requires a full re-embed.
EMBEDDER_MODEL=Qwen/Qwen3-Embedding-0.6B

# Any OpenAI-compatible endpoint. The SiliconFlow `.cn` host is a separate
# account/key namespace from `.com` — use the one your key belongs to.
EMBEDDER_BASE_URL=https://api.siliconflow.cn/v1

# Vector size. Qwen3-Embedding-0.6B max is 1024 (<=2000 keeps it pgvector-indexable).
EMBEDDER_DIMENSIONS=1024

# SECRET — set only in your local `.env`. Required for any live embed call.
EMBEDDER_API_KEY=sk-replace-me-in-dotenv
