# Database configuration (PostgreSQL)
# Used as the persistent data store for the Runtime, including pgvector for the knowledge base and long-term memory.

# Hostname or IP address of the PostgreSQL server.
DB_HOST=localhost
# Port number of the PostgreSQL server.
DB_PORT=5532
# Username for database authentication.
DB_USER=
# Password for database authentication.
DB_PASS=
# Name of the database to connect to.
DB_DATABASE=spectres_runtime

# AgentOS server configuration (required)
# Controls the bind address and port when running AgentOS directly (e.g., python -m spectres.main).

# Interface to bind. Use 127.0.0.1 to accept local connections only.
AGENT_OS_HOST=0.0.0.0
# Port for the AgentOS HTTP server.
AGENT_OS_PORT=7777

# Team Leader Agent configuration (OpenAI-compatible API)
# Used to connect the Team Leader Agent to an open-source or self-hosted LLM through an OpenAI-compatible endpoint (e.g., vLLM, Ollama, LiteLLM proxy).

# Model ID for the Team Leader Agent (e.g., qwen2.5:72b, llama3.1:8b, gpt-4o).
TEAM_LEADER_LLM_MODEL=
# Base URL of the OpenAI-compatible API endpoint for the Team Leader Agent.
TEAM_LEADER_LLM_BASE_URL=
# API key for the Team Leader Agent's OpenAI-compatible endpoint (leave empty if not required).
TEAM_LEADER_LLM_API_KEY=
# Sampling temperature (0.0 - 2.0). Lower = more deterministic.
# TEAM_LEADER_LLM_TEMPERATURE=0.5
# Maximum tokens to generate in a single response.
# TEAM_LEADER_LLM_MAX_COMPLETION_TOKENS=4096
# Optional JSON object with extra HTTP headers for the LLM API.
# TEAM_LEADER_LLM_EXTRA_HEADERS={"User-Agent":"Spectres-Runtime/0.2.1"}
