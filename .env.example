# Database configuration (PostgreSQL)
# Used as the persistent data store for the Runtime, including pgvector for the knowledge base and long-term memory.
DB_HOST=localhost             # Hostname or IP address of the PostgreSQL server.
DB_PORT=5532                  # Port number of the PostgreSQL server.
DB_USER=                      # Username for database authentication.
DB_PASS=                      # Password for database authentication.
DB_DATABASE=spectres_runtime  # Name of the database to connect to.

# Team Leader Agent configuration (OpenAI-compatible API)
# Used to connect the Team Leader Agent to an open-source or self-hosted LLM through an OpenAI-compatible endpoint (e.g., vLLM, Ollama, LiteLLM proxy).
TEAM_LEADER_LLM_MODEL=                # Model ID for the Team Leader Agent (e.g., qwen2.5:72b, llama3.1:8b, gpt-4o).
TEAM_LEADER_LLM_BASE_URL=             # Base URL of the OpenAI-compatible API endpoint for the Team Leader Agent.
TEAM_LEADER_LLM_API_KEY=              # API key for the Team Leader Agent's OpenAI-compatible endpoint (leave empty if not required).
