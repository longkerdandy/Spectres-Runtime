# Spectres Runtime — environment template.
#
# Copy this file to `.env` (git-ignored) and fill in the real values.
# DO NOT commit secrets. Variables map 1:1 to pydantic-settings fields;
# missing required values will fail at startup.

# --- Datastore ---------------------------------------------------------------
# Postgres configuration. The database stores recipes, vector embeddings, and
# conversation history. The compose file uses DATABASE_USERNAME/PASSWORD to
# create the Postgres role; the app uses DATABASE_URL to connect.
DATABASE_USERNAME=replace-me-in-dotenv          # Postgres role name (compose-only).
DATABASE_PASSWORD=replace-me-in-dotenv          # Postgres role password (compose-only).
DATABASE_URL=postgresql+psycopg://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@localhost:5532/spectres_runtime

# --- Runtime server ----------------------------------------------------------
# Local FastAPI / AgentOS server settings. These only affect the dev server;
# production deployments usually override them externally.
RUNTIME_PORT=7777                               # HTTP port the dev server binds to.
SPECTRES_WEB_ORIGIN=http://localhost:3000       # Allowed CORS origin for Spectres-Web.

# --- Embedding provider ------------------------------------------------------
# Hosted embedding model for recipe semantic search. Must expose an
# OpenAI-compatible `/embeddings` endpoint. The model and its output dimension
# form a data contract: changing either requires re-running `recipe-ingest`.
EMBEDDER_MODEL=Qwen/Qwen3-Embedding-0.6B        # Model id on the embedding provider.
EMBEDDER_BASE_URL=https://api.siliconflow.cn/v1 # Provider base URL.
EMBEDDER_DIMENSIONS=1024                        # Must match the model's output dimension.
EMBEDDER_API_KEY=sk-replace-me-in-dotenv        # Provider API key (local `.env` only).

# --- Recipe agent ------------------------------------------------------------
# Chat model that powers the recipe assistant. Any OpenAI-compatible provider
# works here; the agent itself is provider-agnostic.
RECIPE_AGENT_INSTRUCTIONS=""                    # Override the built-in system prompt; leave empty for default.
RECIPE_AGENT_NUM_HISTORY_RUNS=3                 # How many prior turns are replayed into context (memory).
RECIPE_AGENT_CHAT_MODEL=replace-me-with-chat-model-id
RECIPE_AGENT_CHAT_BASE_URL=https://replace-me-with-provider-endpoint/v1
RECIPE_AGENT_CHAT_API_KEY=sk-replace-me-in-dotenv

# Optional OpenAI-compatible chat-model tuning. Uncomment only the parameters
# your provider supports; unsupported parameters will cause request errors.
# RECIPE_AGENT_CHAT_TEMPERATURE=0.7             # Sampling randomness: 0 = deterministic, 2 = very random.
# RECIPE_AGENT_CHAT_TOP_P=0.9                   # Nucleus sampling cutoff (0.0-1.0).
# RECIPE_AGENT_CHAT_MAX_TOKENS=2048             # Max answer tokens only (legacy; excludes reasoning chain).
# RECIPE_AGENT_CHAT_MAX_COMPLETION_TOKENS=4096  # Max total output tokens (answer + reasoning chain).
# RECIPE_AGENT_CHAT_FREQUENCY_PENALTY=0.0       # Penalty for repeating the same tokens (-2.0 to 2.0).
# RECIPE_AGENT_CHAT_PRESENCE_PENALTY=0.0        # Penalty for repeating topics (-2.0 to 2.0).
# RECIPE_AGENT_CHAT_TIMEOUT=60.0                # HTTP request timeout in seconds.
# RECIPE_AGENT_CHAT_SEED=42                     # Fixed seed for reproducible output.
# RECIPE_AGENT_CHAT_THINKING=enabled            # Volcengine thinking mode: enabled / disabled / auto.
# RECIPE_AGENT_CHAT_REASONING_EFFORT=medium     # Reasoning depth: minimal / low / medium / high (provider-specific).
# RECIPE_AGENT_CHAT_REQUEST_PARAMS={"custom_key":"custom_value"}  # Escape hatch for any provider-specific parameter.
