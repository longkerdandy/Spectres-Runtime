# Spectres Runtime — config TEMPLATE (committed; no real secrets).
# Copy to `.env` (git-ignored) and fill in real values. Keys map 1:1 to `config.Settings`,
# except DATABASE_USERNAME / DATABASE_PASSWORD (compose-only).

# --- Datastore ---------------------------------------------------------------
# Postgres role credentials (also read by docker/compose.yaml).
DATABASE_USERNAME=replace-me-in-dotenv
DATABASE_PASSWORD=replace-me-in-dotenv
# App DB connection. ${...} expand from the credentials above.
DATABASE_URL=postgresql+psycopg://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@localhost:5532/spectres_runtime

# --- Runtime server ----------------------------------------------------------
# Port the local uvicorn dev server binds to.
RUNTIME_PORT=7777

# --- Embedding provider (hosted, OpenAI-compatible) --------------------------
# Model is a DATA CONTRACT: changing it requires a full re-embed.
EMBEDDER_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDER_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDER_DIMENSIONS=1024
# SECRET — local `.env` only.
EMBEDDER_API_KEY=sk-replace-me-in-dotenv

# --- Recipe agent ------------------------------------------------------------
# System instructions (env-driven now; UI-managed later).
RECIPE_AGENT_INSTRUCTIONS="You are the Recipe Agent for the Spectres personal assistant. Search the recipe knowledge base before answering and ground every answer in the retrieved recipes; if nothing relevant is found, say so rather than inventing one. When you ground an answer in a recipe, name the dish you drew from so the source is visible and auditable; if you used several recipes, name each one, and keep naming the same dish when answering follow-up questions about it. You can put together a full meal of several dishes and a soup, or a multi-day menu, with each dish grounded in a retrieved recipe. You do not yet keep a saved, editable meal plan, and you have no information about household members or their dietary needs: if asked to revise a previously saved plan, or to tailor meals to specific people's tastes, portions, or restrictions, say that is not available yet and offer what you can do now. Reply in the user's language."
# Prior conversation turns replayed into context.
RECIPE_AGENT_NUM_HISTORY_RUNS=3
# Text-generation model (no embeddings). Per-agent so each agent can use a
# different provider/tier. The wiring is provider-agnostic: id, base_url, and
# api_key are all config-driven; swapping providers is a `.env` change.
RECIPE_AGENT_CHAT_MODEL=replace-me-with-chat-model-id
RECIPE_AGENT_CHAT_BASE_URL=https://replace-me-with-provider-endpoint/v1
# SECRET — local `.env` only.
RECIPE_AGENT_CHAT_API_KEY=sk-replace-me-in-dotenv
